<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>Ember Empire Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-slate-900 text-white min-h-screen">

<div class="max-w-7xl mx-auto p-6">

  <div class="flex items-center justify-between mb-8">

    <div>

      <h1 class="text-4xl font-bold">
        🔥 Ember Empire Dashboard
      </h1>

      <p class="opacity-70 mt-2">
        Logged in as
        <%= user.username %>
      </p>

    </div>

    <a
      href="/logout"
      class="bg-red-600 hover:bg-red-700 px-5 py-3 rounded-xl"
    >
      Logout
    </a>

  </div>

  <!-- BATTLE CARDS -->

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

  <% if (battles && battles.length) { %>

  <% battles.forEach(b => { %>

  <div class="bg-slate-800 rounded-2xl overflow-hidden shadow-lg border border-slate-700">

    <% if (b.posterdata) { %>

    <img
      src="/poster/<%= b.id %>"
      alt="Battle Poster"
      class="w-full h-[420px] object-cover"
    />

    <% } else { %>

    <div class="w-full h-[420px] bg-slate-700 flex items-center justify-center text-slate-400">
      No Poster
    </div>

    <% } %>

    <div class="p-5">

      <h2 class="text-xl font-bold mb-2">
        ⚔ <%= b.hostdisplayname || b.hostname || b.host %>
        vs
        <%= b.opponent || "Unknown" %>
      </h2>

      <div class="space-y-1 text-sm opacity-80">

        <p>📅 <%= b.date || "—" %></p>

        <p>⏰ <%= b.time || "—" %></p>

      </div>

      <div class="flex flex-wrap gap-2 mt-4">

        <% if (b.managergifting) { %>
        <span class="bg-purple-600 px-2 py-1 rounded text-xs">
          🎁 Manager Gifting
        </span>
        <% } %>

        <% if (b.adultonly) { %>
        <span class="bg-red-600 px-2 py-1 rounded text-xs">
          🔞 18+
        </span>
        <% } %>

        <% if (b.powerups) { %>
        <span class="bg-yellow-500 text-black px-2 py-1 rounded text-xs">
          ⚡ Powerups
        </span>
        <% } %>

        <% if (b.nohammers) { %>
        <span class="bg-slate-600 px-2 py-1 rounded text-xs">
          🔨 No Hammers
        </span>
        <% } %>

      </div>

      <% if (b.livelink) { %>

      <a
        href="<%= b.livelink %>"
        target="_blank"
        class="mt-4 inline-block bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg"
      >
        🔗 Watch Battle
      </a>

      <% } %>

      <% if (
        roleLevel === "admin" ||
        roleLevel === "owner"
      ) { %>

      <div class="mt-4">

        <form
          action="/battle/<%= b.id %>/delete"
          method="POST"
        >

          <button
            class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg"
          >
            Delete
          </button>

        </form>

      </div>

      <% } %>

    </div>

  </div>

  <% }) %>

  <% } else { %>

  <div class="col-span-full text-center opacity-60 py-10">

    No battles scheduled yet.

  </div>

  <% } %>

  </div>

</div>

</body>

</html>