<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flame Force Dashboard</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>
<body class="bg-slate-900 text-white min-h-screen">

<div class="max-w-6xl mx-auto px-6 py-8">

<!-- HEADER -->

<div class="flex justify-between items-center mb-6">

<h1 class="text-3xl font-bold">🔥 Flame Force Dashboard</h1>

<div class="flex gap-4 items-center">

<% if (user) { %>
<span class="text-sm opacity-70">
Logged in
</span>

<a href="/logout"
class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg">
Logout
</a>

<% } else { %>

<a href="/login"
class="bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg">
Login with Discord
</a>

<% } %>

</div>
</div>


<!-- SEARCH BAR -->

<form method="GET" class="mb-6">

<input
type="text"
name="q"
placeholder="Search host or opponent..."
value="<%= (filters && filters.q) || '' %>"
class="bg-slate-800 px-4 py-2 rounded-lg w-full"
/>

</form>


<!-- CREATE BUTTON -->

<% if (roleLevel === "admin" || roleLevel === "owner") { %>

<div class="mb-6">

<a href="#createBattle"
class="bg-green-600 hover:bg-green-700 px-4 py-2 rounded-lg inline-block">
➕ Create Battle
</a>

</div>

<% } %>


<!-- BATTLE TABLE -->

<div class="bg-slate-800 rounded-xl overflow-hidden">

<table class="w-full">

<thead class="bg-slate-700 text-left">

<tr>
<th class="p-3">Host</th>
<th class="p-3">Opponent</th>
<th class="p-3">Date</th>
<th class="p-3">Time</th>

<% if (roleLevel === "admin" || roleLevel === "owner") { %>
<th class="p-3">Actions</th>
<% } %>

</tr>

</thead>

<tbody>

<% if (battles && battles.length) { %>

<% battles.forEach(b => { %>

<tr class="border-t border-slate-700">

<td class="p-3">
<%= b.hostDisplayName || b.hostname || b.host %>
</td>

<td class="p-3">
<%= b.opponent || "—" %>
</td>

<td class="p-3">
<%= b.date || "—" %>
</td>

<td class="p-3">
<%= b.time || "—" %>
</td>

<% if (roleLevel === "admin" || roleLevel === "owner") { %>

<td class="p-3 flex gap-2">

<form action="/battle/<%= b.id %>/delete" method="POST">

<button
class="bg-red-600 hover:bg-red-700 px-3 py-1 rounded">
Delete
</button>

</form>

</td>

<% } %>

</tr>

<% }) %>

<% } else { %>

<tr>

<td colspan="5" class="p-6 text-center opacity-60">
No battles scheduled yet.
</td>

</tr>

<% } %>

</tbody>

</table>

</div>


<!-- CREATE FORM -->

<% if (roleLevel === "admin" || roleLevel === "owner") { %>

<div id="createBattle" class="mt-10 bg-slate-800 p-6 rounded-xl">

<h2 class="text-xl font-semibold mb-4">
Create Battle
</h2>

<form method="POST" action="/create-battle" enctype="multipart/form-data">

<div class="grid grid-cols-2 gap-4">

<select name="host"
class="bg-slate-700 p-2 rounded">

<% if (agencyMembers && agencyMembers.length) { %>

<% agencyMembers.forEach(m => { %>

<option value="<%= m.id %>">
<%= m.username %>
</option>

<% }) %>

<% } %>

</select>

<input
name="hostName"
placeholder="Host display override"
class="bg-slate-700 p-2 rounded"
/>

<input
name="opponent"
placeholder="Opponent"
class="bg-slate-700 p-2 rounded"
/>

<input
type="date"
name="date"
class="bg-slate-700 p-2 rounded"
/>

<input
type="time"
name="time"
class="bg-slate-700 p-2 rounded"
/>

<input
name="liveLink"
placeholder="Live link"
class="bg-slate-700 p-2 rounded"
/>

<label class="flex items-center gap-2">
<input type="checkbox" name="managergifting">
Manager gifting
</label>

<label class="flex items-center gap-2">
<input type="checkbox" name="adultonly">
18+
</label>

<label class="flex items-center gap-2">
<input type="checkbox" name="powerups">
Powerups
</label>

<label class="flex items-center gap-2">
<input type="checkbox" name="nohammers">
No hammers
</label>

<input
type="file"
name="poster"
class="col-span-2"
/>

</div>

<button
class="mt-4 bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg">
Create Battle
</button>

</form>

</div>

<% } %>

</div>

</body>
</html>