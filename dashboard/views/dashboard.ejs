<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">
<title>Flame Force Dashboard</title>

<link rel="icon" href="/favicon.png">

<style>

body{
background:#0d0d0d;
color:white;
font-family:Segoe UI;
margin:0;
}

/* HEADER */

header{
display:flex;
align-items:center;
gap:15px;
padding:20px;
background:#111;
border-bottom:2px solid #ff6600;
}

.logo{
height:60px;
}

.container{
padding:30px;
}

/* CREATE PANEL */

.create-card{
background:#111;
padding:25px;
border-radius:14px;
margin-bottom:40px;
box-shadow:0 0 20px rgba(255,120,0,.25);
}

.grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:15px;
}

.rules-grid{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:12px;
margin-top:20px;
}

input,select{
padding:10px;
border-radius:6px;
border:none;
background:#222;
color:white;
}

.create-btn{
margin-top:20px;
width:100%;
font-size:16px;
padding:14px;
background:linear-gradient(45deg,#ff6600,#ff3300);
border:none;
border-radius:10px;
color:white;
cursor:pointer;
}

.create-btn:hover{
transform:scale(1.03);
}

/* BATTLE CARDS */

.card{
background:#111;
padding:20px;
border-radius:12px;
margin-bottom:25px;
border-left:4px solid #ff6600;
}

.poster{
width:220px;
border-radius:10px;
margin-top:10px;
}

.rules{
font-size:13px;
margin-top:10px;
color:#bbb;
}

.poster-replace{
margin-top:10px;
display:flex;
gap:10px;
}

button{
background:#ff6600;
border:none;
padding:8px 14px;
color:white;
cursor:pointer;
border-radius:6px;
}

button:hover{
background:#ff8533;
}

</style>

</head>

<body>

<header>

<img src="/logo.png" class="logo">

<h2>Flame Force Battle Dashboard</h2>

</header>

<div class="container">

<% if(roleLevel==="owner"||roleLevel==="admin"){ %>

<div class="create-card">

<h3>Create Battle</h3>

<form action="/create"
method="POST"
enctype="multipart/form-data">

<div class="grid">

<div>

<label>Creator</label>

<select name="host" required>

<% agencyMembers.forEach(member=>{ %>

<option value="<%= member.id %>">
<%= member.name %>
</option>

<% }) %>

</select>

</div>

<div>

<label>Opponent</label>

<input
type="text"
name="opponent"
placeholder="TikTok username"
required>

</div>

<div>

<label>Date</label>

<input type="date" name="date" required>

</div>

<div>

<label>Time</label>

<input type="time" name="time" required>

</div>

<div>

<label>Live Link</label>

<input
type="text"
name="liveLink"
placeholder="Optional livestream link">

</div>

<div>

<label>Poster</label>

<input
type="file"
name="poster"
accept="image/*">

</div>

</div>

<div class="rules-grid">

<label>

Manager Gifting

<select name="managerGifting">

<option value="true">Allowed</option>

<option value="false">Disabled</option>

</select>

</label>

<label>

18+

<select name="adultOnly">

<option value="false">Off</option>

<option value="true">On</option>

</select>

</label>

<label>

Power Ups

<select name="powerUps">

<option value="true">Allowed</option>

<option value="false">Disabled</option>

</select>

</label>

<label>

No Hammers

<select name="noHammers">

<option value="false">Allowed</option>

<option value="true">Enabled</option>

</select>

</label>

</div>

<button class="create-btn">

Create Battle

</button>

</form>

</div>

<% } %>

<h3>Scheduled Battles</h3>

<% battles.forEach(battle=>{ %>

<div class="card">

<strong>

⚔ <%= battle.hostName %> vs <%= battle.opponent %>

</strong>

<br>

📅 <%= battle.date %>

⏰ <%= battle.time %>

<% if(battle.liveLink){ %>

<br>

🔗

<a href="<%= battle.liveLink %>"
target="_blank">

Watch Battle

</a>

<% } %>

<div class="rules">

🎁 Manager Gifting:

<%= battle.managergifting ? "Allowed" : "Disabled" %>

|

🔞 18+:

<%= battle.adultonly ? "On" : "Off" %>

|

⚡ Power Ups:

<%= battle.powerups ? "Allowed" : "Disabled" %>

|

🔨 No Hammers:

<%= battle.nohammers ? "Enabled" : "Allowed" %>

</div>

<img
class="poster"
src="/poster/<%= battle.id %>?t=<%= Date.now() %>">

<% if(roleLevel==="owner"||roleLevel==="admin"){ %>

<form
action="/replace-poster/<%= battle.id %>"
method="POST"
enctype="multipart/form-data"
class="poster-replace">

<input
type="file"
name="poster"
required>

<button>

Replace Poster

</button>

</form>

<form
action="/delete/<%= battle.id %>"
method="POST">

<button>

Delete Battle

</button>

</form>

<% } %>

</div>

<% }) %>

</div>

</body>
</html>