<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Flame Force Dashboard</title>

<link rel="icon" href="/favicon.png">

<style>

body{
margin:0;
font-family:Segoe UI,Arial;
background:#0e0e0e;
color:white;
}

/* HEADER */

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 40px;
background:#111;
border-bottom:2px solid #ff6600;
}

.logo img{
height:52px;
animation:glowPulse 2.5s infinite alternate ease-in-out;
}

@keyframes glowPulse{
0%{filter:drop-shadow(0 0 8px #ff6600);}
100%{filter:drop-shadow(0 0 22px #ffaa00);}
}

.nav a{
margin-left:22px;
color:#ff6600;
font-weight:600;
text-decoration:none;
}

/* PAGE WRAPPER */

.wrapper{
padding:40px;
max-width:1300px;
margin:auto;
}

/* FORM */

.form-box{
background:#1a1a1a;
padding:28px;
border-radius:14px;
margin-bottom:50px;
box-shadow:0 0 18px rgba(255,120,0,.15);
}

.form-box h2{
margin-top:0;
color:#ffaa00;
}

.form-box input,
.form-box select{
width:100%;
padding:10px;
margin-top:8px;
margin-bottom:18px;
border-radius:6px;
border:none;
background:#0f0f0f;
color:white;
}

button{
background:#ff6600;
border:none;
padding:10px 16px;
color:white;
font-weight:bold;
border-radius:6px;
cursor:pointer;
}

button:hover{
background:#ffaa00;
}

/* GRID */

.grid{
display:grid;
grid-template-columns:repeat(auto-fill,minmax(320px,1fr));
gap:28px;
}

/* CARD */

.card{
background:#1b1b1b;
border-radius:14px;
padding:20px;
box-shadow:0 0 18px rgba(255,100,0,.15);
position:relative;
transition:.25s;
}

.card:hover{
transform:translateY(-5px);
box-shadow:0 0 26px rgba(255,150,0,.35);
}

.poster{
width:100%;
border-radius:10px;
margin-top:12px;
}

.meta{
font-size:14px;
opacity:.85;
margin-top:6px;
}

/* RULE BADGES */

.rule{
display:inline-block;
padding:4px 8px;
margin:4px 4px 0 0;
border-radius:6px;
font-size:12px;
font-weight:600;
}

.allowed{background:#2ecc71;}
.denied{background:#c0392b;}
.warning{background:#e67e22;}
.highlight{background:#9b59b6;}

/* EDIT PANEL */

.edit-panel{
margin-top:14px;
border-top:1px solid #333;
padding-top:14px;
}

.edit-panel input,
.edit-panel select{
margin-bottom:10px;
}

/* DELETE BUTTON */

.delete-btn{
background:#aa0000;
margin-top:8px;
}

.delete-btn:hover{
background:#ff0000;
}

</style>
</head>

<body>

<header>

<div class="logo">
<img src="/logo.png">
</div>

<div class="nav">
<a href="/dashboard">Dashboard</a>
<a href="/calendar">Calendar</a>
<a href="/logout">Logout</a>
</div>

</header>

<div class="wrapper">

<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<div class="form-box">

<h2>Create Battle</h2>

<form
action="/create"
method="POST"
enctype="multipart/form-data"
>

<label>Host</label>

<select name="host" required>

<% agencyMembers.forEach(member=>{ %>

<option value="<%= member.id %>">
<%= member.name %>
</option>

<% }) %>

</select>

<label>Opponent</label>

<input
type="text"
name="opponent"
required
placeholder="Enter opponent username"
/>

<label>Date</label>
<input type="date" name="date" required>

<label>Time</label>
<input type="time" name="time" required>

<label>Poster</label>
<input type="file" name="poster">

<label>Live Link</label>
<input type="text" name="liveLink">

<label>Manager Gifting</label>

<select name="managerGifting">
<option value="true">Allowed</option>
<option value="false">Not Allowed</option>
</select>

<label>18+ Battle</label>

<select name="adultOnly">
<option value="false">Off</option>
<option value="true">On 🔞</option>
</select>

<label>Power-Ups</label>

<select name="powerUps">
<option value="true">Allowed ⚡</option>
<option value="false">Not Allowed</option>
</select>

<label>Hammers</label>

<select name="noHammers">
<option value="false">Allowed 🔨</option>
<option value="true">No Hammers</option>
</select>

<button type="submit">
Create Battle
</button>

</form>

</div>

<% } %>


<div class="grid">

<% battles.forEach(battle=>{ %>

<div class="card">

<h3>
⚔ <%= battle.host %> vs <%= battle.opponent %>
</h3>

<div class="meta">
📅 <%= battle.date %>
</div>

<div class="meta">
⏰ <%= battle.time %>
</div>


<div>

<span class="rule <%= battle.managergifting ? 'allowed':'denied' %>">
🎁 Gifting
</span>

<span class="rule <%= battle.adultonly ? 'warning':'allowed' %>">
🔞 18+
</span>

<span class="rule <%= battle.powerups ? 'allowed':'denied' %>">
⚡ Power-Ups
</span>

<span class="rule <%= battle.nohammers ? 'denied':'allowed' %>">
🔨 Hammers
</span>

</div>


<% if(battle.poster){ %>

<img
class="poster"
src="<%= battle.poster %>"
>

<% } %>


<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<div class="edit-panel">

<form
action="/edit/<%= battle.id %>"
method="POST"
enctype="multipart/form-data"
>

<input
type="text"
name="opponent"
value="<%= battle.opponent %>"
required
>

<input
type="date"
name="date"
value="<%= battle.date %>"
required
>

<input
type="time"
name="time"
value="<%= battle.time %>"
required
>

<select name="managerGifting">
<option value="true" <%= battle.managergifting ? "selected":"" %>>
Allowed
</option>
<option value="false" <%= !battle.managergifting ? "selected":"" %>>
Not Allowed
</option>
</select>

<select name="adultOnly">
<option value="true" <%= battle.adultonly ? "selected":"" %>>
18+ On
</option>
<option value="false" <%= !battle.adultonly ? "selected":"" %>>
18+ Off
</option>
</select>

<select name="powerUps">
<option value="true" <%= battle.powerups ? "selected":"" %>>
Allowed
</option>
<option value="false" <%= !battle.powerups ? "selected":"" %>>
Not Allowed
</option>
</select>

<select name="noHammers">
<option value="true" <%= battle.nohammers ? "selected":"" %>>
No Hammers
</option>
<option value="false" <%= !battle.nohammers ? "selected":"" %>>
Allowed
</option>
</select>

<button type="submit">
Save Changes
</button>

</form>


<form
action="/delete/<%= battle.id %>"
method="POST"
>

<button
class="delete-btn"
type="submit"
>

Delete Battle

</button>

</form>

</div>

<% } %>

</div>

<% }) %>

</div>

</div>

</body>
</html>