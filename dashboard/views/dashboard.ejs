<!DOCTYPE html>
<html>

<head>

<title>Flame Force Dashboard</title>

<link rel="icon" href="/favicon.png">

<style>

body{
background:#0b0b0b;
color:white;
font-family:Arial;
margin:0;
}

.topbar{

display:flex;
align-items:center;
justify-content:space-between;

background:#111;
padding:12px 20px;

border-bottom:2px solid #ff4d00;

}

.logo{

height:46px;

animation:glow 2.5s infinite alternate;

}

@keyframes glow{

from{filter:drop-shadow(0 0 3px #ff4d00);}
to{filter:drop-shadow(0 0 18px #ff4d00);}

}

.nav-buttons a{

margin-left:12px;
text-decoration:none;

background:#ff4d00;
color:white;

padding:8px 14px;
border-radius:6px;

}

.nav-buttons a:hover{

background:#ff7a33;

}

.container{

padding:30px;

}

.create-box{

background:#151515;
padding:20px;
border-radius:10px;
margin-bottom:30px;

}

input,select{

padding:8px;
margin:6px;
border-radius:5px;
border:none;

}

button{

background:#ff4d00;
border:none;
padding:10px 14px;
color:white;
border-radius:6px;

cursor:pointer;

}

button:hover{

background:#ff7a33;

}

.battle-card{

background:#151515;
margin-bottom:18px;
padding:18px;
border-radius:10px;

display:flex;
gap:20px;

align-items:center;

}

.poster{

width:120px;
height:120px;
object-fit:cover;
border-radius:8px;

}

</style>

</head>

<body>


<!-- TOP NAV BAR -->

<div class="topbar">

<img src="/logo.png" class="logo">

<div class="nav-buttons">

<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<a href="/dashboard">Dashboard</a>

<% } %>

<a href="/calendar">Calendar</a>

<a href="/logout">Logout</a>

</div>

</div>



<div class="container">


<!-- CREATE BATTLE FORM (ADMIN / OWNER ONLY) -->

<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<div class="create-box">

<h2>Create Battle</h2>

<form method="POST" action="/create" enctype="multipart/form-data">

<select name="host" required>

<% agencyMembers.forEach(member=>{ %>

<option value="<%= member.id %>">

<%= member.name %>

</option>

<% }) %>

</select>


<input name="opponent" placeholder="Opponent Username" required>

<input type="date" name="date" required>

<input type="time" name="time" required>

<input type="file" name="poster">


<br><br>


<label>Manager Gifting</label>

<select name="managerGifting">

<option value="true">Allowed</option>
<option value="false">Disabled</option>

</select>


<label>18+</label>

<select name="adultOnly">

<option value="false">Off</option>
<option value="true">On</option>

</select>


<label>Power Ups</label>

<select name="powerUps">

<option value="true">Allowed</option>
<option value="false">Disabled</option>

</select>


<label>No Hammers</label>

<select name="noHammers">

<option value="true">Enabled</option>
<option value="false">Disabled</option>

</select>


<br><br>

<button>Create Battle</button>

</form>

</div>

<% } %>



<!-- BATTLE LIST -->

<h2>Scheduled Battles</h2>

<% battles.forEach(b=>{ %>

<div class="battle-card">


<img src="/poster/<%= b.id %>" class="poster">


<div>

<h3>

<%= b.hostName %> vs <%= b.opponent %>

</h3>

<p>

📅 <%= b.date %>  
⏰ <%= b.time %>

</p>

</div>


<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<form method="POST" action="/delete/<%= b.id %>">

<button>Delete</button>

</form>

<% } %>


</div>

<% }) %>


</div>

</body>
</html>