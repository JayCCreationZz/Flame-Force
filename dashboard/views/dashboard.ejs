<form
action="/create"
method="POST"
enctype="multipart/form-data"
class="bg-slate-900 p-6 rounded-2xl shadow-xl space-y-5"
>

<h2 class="text-xl font-bold text-orange-400">
Create Battle
</h2>


<!-- HOST DROPDOWN -->

<label class="block text-sm text-slate-300">
Host Creator
</label>

<select
name="host"
required
onchange="setHostName(this)"
class="w-full px-4 py-2 rounded-xl bg-slate-800 border border-slate-600 text-white"
>

<option value="">Select creator</option>

<% agencyMembers.forEach(member=>{ %>

<option value="<%= member.id %>">
<%= member.name %>
</option>

<% }) %>

</select>


<input
type="hidden"
name="hostName"
id="hostNameField"
/>



<!-- OPPONENT FIELD -->

<label class="block text-sm text-slate-300">
Opponent Creator
</label>

<input
type="text"
name="opponent"
required
placeholder="Enter opponent username"
class="w-full px-4 py-2 rounded-xl bg-slate-800 border border-slate-600 text-white"
/>



<!-- DATE + TIME PICKERS -->

<div class="grid grid-cols-2 gap-4">

<div class="relative">

<label class="block mb-1 text-sm text-slate-300">
Battle Date
</label>

<span class="absolute left-3 top-9 text-slate-400">
📅
</span>

<input
type="date"
name="date"
required
min="<%= new Date().toISOString().split('T')[0] %>"
class="pl-9 w-full px-4 py-2 rounded-xl bg-slate-800 border border-slate-600 text-white"
/>

</div>


<div class="relative">

<label class="block mb-1 text-sm text-slate-300">
Battle Time
</label>

<span class="absolute left-3 top-9 text-slate-400">
🕒
</span>

<input
type="time"
name="time"
required
class="pl-9 w-full px-4 py-2 rounded-xl bg-slate-800 border border-slate-600 text-white"
/>

</div>

</div>



<!-- LIVE LINK -->

<label class="block text-sm text-slate-300">
TikTok Live Link (optional)
</label>

<input
type="text"
name="liveLink"
placeholder="https://tiktok.com/@creator/live"
class="w-full px-4 py-2 rounded-xl bg-slate-800 border border-slate-600 text-white"
/>



<!-- POSTER UPLOAD -->

<label class="block text-sm text-slate-300">
Battle Poster
</label>

<input
type="file"
name="poster"
accept="image/*"
required
class="w-full px-4 py-2 rounded-xl bg-slate-800 border border-slate-600 text-white"
/>



<!-- RULE TOGGLES -->

<div class="grid grid-cols-2 gap-4 text-sm text-slate-300">

<label>
<input type="checkbox" name="managerGifting" value="true">
Manager gifting allowed
</label>

<label>
<input type="checkbox" name="adultOnly" value="true">
18+ only
</label>

<label>
<input type="checkbox" name="powerUps" value="true">
Powerups allowed
</label>

<label>
<input type="checkbox" name="noHammers" value="true">
No hammers
</label>

</div>



<!-- SUBMIT BUTTON -->

<button
type="submit"
class="w-full py-3 rounded-xl bg-orange-500 hover:bg-orange-600 font-semibold"
>

Create Battle

</button>

</form>



<script>

function setHostName(select){

const selectedText =
select.options[select.selectedIndex].text;

document.getElementById("hostNameField").value =
selectedText;

}

</script>