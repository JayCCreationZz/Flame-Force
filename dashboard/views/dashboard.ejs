<!DOCTYPE html>
<html>
<head>
  <title>Flame Force Dashboard</title>
  <script src="https://cdn.tailwindcss.com"></script>

  <style>
    body{
      background:linear-gradient(135deg,#020617,#0f172a);
      color:white;
    }

    .logo{
      animation:pulseGlow 2.2s infinite ease-in-out;
    }

    @keyframes pulseGlow{
      0%{filter:drop-shadow(0 0 10px rgba(255,80,0,.5));}
      50%{
        filter:
        drop-shadow(0 0 28px rgba(255,80,0,.95))
        drop-shadow(0 0 50px rgba(255,40,0,.5));
      }
      100%{filter:drop-shadow(0 0 10px rgba(255,80,0,.5));}
    }

    .card{
      background:rgba(30,41,59,.75);
      backdrop-filter:blur(12px);
      border-radius:18px;
      border:1px solid rgba(255,80,0,.25);
    }

    .poster{
      border-radius:12px;
      max-height:180px;
      object-fit:cover;
    }
  </style>
</head>

<body>

<div class="max-w-7xl mx-auto px-6 py-10">

<!-- NAVBAR -->
<div class="flex justify-between items-center mb-10">

  <div class="flex items-center gap-4">
    <img src="/logo.png" class="logo w-14">
    <h1 class="text-3xl font-bold">Flame Force Dashboard</h1>
  </div>

  <div class="flex gap-3">

    <% if(roleLevel === "owner" || roleLevel === "admin"){ %>
      <a href="/dashboard" class="bg-slate-700 px-5 py-2 rounded-xl">Dashboard 🔥</a>
    <% } %>

    <a href="/calendar" class="bg-orange-500 px-5 py-2 rounded-xl">Calendar 📅</a>

    <a href="/logout" class="bg-red-600 px-5 py-2 rounded-xl">Logout</a>

  </div>
</div>


<!-- CREATE BATTLE -->
<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<div class="card p-6 mb-10">

<h2 class="text-xl font-semibold mb-4">Create Battle</h2>

<form action="/create" method="POST" enctype="multipart/form-data" class="grid grid-cols-2 gap-4">

<select name="host" required class="text-black p-2 rounded">

<option value="">Select Host</option>

<% agencyMembers.forEach(member=>{ %>
<option value="<%= member.id %>"><%= member.name %></option>
<% }) %>

</select>

<input type="text" name="opponent" placeholder="Opponent" required class="text-black p-2 rounded">
<input type="text" name="date" placeholder="DD/MM/YYYY" required class="text-black p-2 rounded">
<input type="text" name="time" placeholder="HH:MM" required class="text-black p-2 rounded">

<input type="file" name="poster" class="col-span-2">

<button class="bg-orange-500 px-5 py-2 rounded col-span-2">Create Battle</button>

</form>

</div>

<% } %>


<!-- BATTLES -->
<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% battles.forEach(b=>{ %>

<div class="card p-5">

<img src="/poster/<%= b.id %>?t=<%= Date.now() %>" class="poster mb-4">

<h3 class="text-lg text-orange-400 font-semibold">
🔥 <%= b.hostName || b.host %> vs <%= b.opponent %>
</h3>

<p>📅 <%= b.date %></p>
<p class="mb-3">⏰ <%= b.time %></p>

<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<form action="/delete/<%= b.id %>" method="POST">
<button class="bg-red-600 px-3 py-1 rounded">Delete</button>
</form>

<% } %>

</div>

<% }) %>

</div>

</div>
</body>
</html>