<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Flame Force Dashboard</title>

<link rel="icon" href="/favicon.png">

<style>

body {
    font-family: Arial;
    background:#0e0e0e;
    color:white;
    margin:0;
}

/* HEADER */

header {
    display:flex;
    align-items:center;
    justify-content:space-between;
    background:#111;
    padding:14px 30px;
    border-bottom:2px solid #ff6600;
    position:relative;
    z-index:1000;
}

/* ANIMATED EMBLEM */

.logo img {
    height:48px;
    animation: flameGlow 2.5s infinite alternate ease-in-out;
}

@keyframes flameGlow {

0% {
    filter:
        drop-shadow(0 0 4px #ff6600)
        drop-shadow(0 0 8px #ff3300);
}

100% {
    filter:
        drop-shadow(0 0 10px #ffaa00)
        drop-shadow(0 0 22px #ff2200);
}

}

/* NAV */

.nav a {
    margin-left:20px;
    text-decoration:none;
    color:#ff6600;
    font-weight:bold;
}

/* PAGE WRAPPER */

.container {
    padding:30px;
}

/* CREATE PANEL */

.form-box {
    background:#1a1a1a;
    padding:25px;
    border-radius:12px;
    margin-bottom:30px;
    box-shadow:0 0 12px rgba(255,120,0,.2);
}

input, select {

    width:100%;
    padding:10px;
    margin-top:8px;
    margin-bottom:16px;
    border:none;
    border-radius:6px;
}

/* BUTTONS */

button {

    padding:10px 16px;
    border:none;
    border-radius:6px;
    cursor:pointer;
    font-weight:bold;
}

.create-btn {
    background:#ff6600;
    color:white;
}

.edit-btn {
    background:#ffaa00;
    margin-right:8px;
}

.delete-btn {
    background:#ff3333;
    color:white;
}

/* CARD */

.card {

    background:#1a1a1a;
    padding:20px;
    border-radius:12px;
    margin-bottom:20px;

    box-shadow:
        0 0 12px rgba(255,120,0,.15);
}

/* POSTER */

.poster {

    width:180px;
    border-radius:10px;
    margin-top:10px;

    box-shadow:
        0 0 10px rgba(255,120,0,.4);
}

/* META */

.meta {

    opacity:.7;
    font-size:13px;
}

</style>
</head>

<body>

<header>

<div class="logo">
<img src="/logo.png">
</div>

<div class="nav">
<a href="/dashboard">Dashboard</a>
<a href="/calendar">Calendar</a>
<a href="/logout">Logout</a>
</div>

</header>

<div class="container">

<% if (roleLevel === "owner" || roleLevel === "admin") { %>

<div class="form-box">

<h2>Create Battle</h2>

<form action="/create" method="POST" enctype="multipart/form-data">

<label>Host Creator (Agency)</label>

<select name="host" required>

<% agencyMembers.forEach(member => { %>

<option value="<%= member.id %>">
<%= member.name %>
</option>

<% }) %>

</select>


<label>Opponent (External or Agency)</label>

<input
type="text"
name="opponent"
placeholder="Enter opponent TikTok username"
required>


<label>Date</label>
<input type="date" name="date" required>

<label>Time</label>
<input type="time" name="time" required>


<label>Live Link</label>
<input type="text" name="liveLink">


<label>Poster Upload</label>
<input type="file" name="poster">


<button class="create-btn">

Create Battle

</button>

</form>

</div>

<% } %>


<h2>Scheduled Battles</h2>


<% battles.forEach(battle => { %>

<div class="card">

<form
action="/edit/<%= battle.id %>"
method="POST"
enctype="multipart/form-data">

<label>Host</label>

<select name="host">

<% agencyMembers.forEach(member => { %>

<option
value="<%= member.id %>"
<%= member.id == battle.host ? "selected" : "" %>>

<%= member.name %>

</option>

<% }) %>

</select>


<label>Opponent</label>

<input
type="text"
name="opponent"
value="<%= battle.opponent %>">


<label>Date</label>

<input
type="date"
name="date"
value="<%= battle.date %>">


<label>Time</label>

<input
type="time"
name="time"
value="<%= battle.time %>">


<label>Live Link</label>

<input
type="text"
name="liveLink"
value="<%= battle.liveLink || "" %>">


<label>Replace Poster</label>

<input type="file" name="poster">


<div class="meta">

Battle ID:
<%= battle.id %>

</div>


<% if (battle.poster) { %>

<img
class="poster"
src="<%= battle.poster %>">

<% } %>


<br><br>

<% if (roleLevel === "owner" || roleLevel === "admin") { %>

<button class="edit-btn">

Save Changes

</button>

</form>


<form
style="display:inline"
action="/delete/<%= battle.id %>"
method="POST">

<button class="delete-btn">

Delete

</button>

</form>

<% } %>

</div>

<% }) %>

</div>

</body>
</html>