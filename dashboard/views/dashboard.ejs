<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>Flame Force Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-slate-900 text-white min-h-screen">

<div class="max-w-7xl mx-auto p-6">

  <!-- HEADER -->

  <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-8">

    <div>

      <h1 class="text-4xl font-bold">
        🔥 Flame Force Dashboard
      </h1>

      <p class="opacity-70 mt-2">
        Logged in as
        <%= user.username %>
      </p>

    </div>

    <div class="flex gap-3">

      <a
        href="/battle/new"
        class="bg-indigo-600 hover:bg-indigo-700 px-5 py-3 rounded-xl"
      >
        ➕ Create Battle
      </a>

      <a
        href="/logout"
        class="bg-red-600 hover:bg-red-700 px-5 py-3 rounded-xl"
      >
        Logout
      </a>

    </div>

  </div>

  <!-- BATTLE GRID -->

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

  <% if (battles && battles.length) { %>

  <% battles.forEach(b => { %>

  <div class="bg-slate-800 rounded-2xl overflow-hidden shadow-lg border border-slate-700">

    <!-- POSTER -->

    <% if (b.posterdata) { %>

    <img
      src="/poster/<%= b.id %>"
      alt="Battle Poster"
      class="w-full h-[420px] object-cover"
    />

    <% } else { %>

    <div class="w-full h-[420px] bg-slate-700 flex items-center justify-center text-slate-400 text-lg">

      No Poster

    </div>

    <% } %>

    <!-- CONTENT -->

    <div class="p-5">

      <h2 class="text-2xl font-bold mb-3">

        ⚔
        <%= b.hostdisplayname || b.hostname || b.host %>

        vs

        <%= b.opponent || "Unknown" %>

      </h2>

      <!-- DATE/TIME -->

      <div class="space-y-2 text-sm opacity-80">

        <p>
          📅
          <%= b.date || "—" %>
        </p>

        <p>
          ⏰
          <%= b.time || "—" %>
        </p>

      </div>

      <!-- TAGS -->

      <div class="flex flex-wrap gap-2 mt-5">

        <% if (b.managergifting) { %>

        <span class="bg-purple-600 px-2 py-1 rounded text-xs">
          🎁 Manager Gifting
        </span>

        <% } %>

        <% if (b.adultonly) { %>

        <span class="bg-red-600 px-2 py-1 rounded text-xs">
          🔞 18+
        </span>

        <% } %>

        <% if (b.powerups) { %>

        <span class="bg-yellow-500 text-black px-2 py-1 rounded text-xs">
          ⚡ Powerups
        </span>

        <% } %>

        <% if (b.nohammers) { %>

        <span class="bg-slate-600 px-2 py-1 rounded text-xs">
          🔨 No Hammers
        </span>

        <% } %>

      </div>

      <!-- WATCH LINK -->

      <% if (b.livelink) { %>

      <a
        href="<%= b.livelink %>"
        target="_blank"
        class="mt-5 inline-block bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg"
      >
        🔗 Watch Battle
      </a>

      <% } %>

      <!-- ADMIN BUTTONS -->

      <% if (
        roleLevel === "admin" ||
        roleLevel === "owner"
      ) { %>

      <div class="flex gap-3 mt-5">

        <!-- EDIT -->

        <a
          href="/battle/<%= b.id %>/edit"
          class="bg-yellow-500 hover:bg-yellow-600 text-black px-4 py-2 rounded-lg"
        >
          ✏ Edit
        </a>

        <!-- DELETE -->

        <form
          action="/battle/<%= b.id %>/delete"
          method="POST"
        >

          <button
            class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg"
          >
            🗑 Delete
          </button>

        </form>

      </div>

      <% } %>

    </div>

  </div>

  <% }) %>

  <% } else { %>

  <div class="col-span-full text-center opacity-60 py-20 text-xl">

    No battles scheduled yet.

  </div>

  <% } %>

  </div>

</div>

</body>

</html>