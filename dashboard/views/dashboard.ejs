<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Flame Force Dashboard</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gray-900 text-white min-h-screen">

<!-- HEADER -->
<header class="flex justify-between items-center px-8 py-4 bg-gray-800 shadow">

    <div class="flex items-center gap-4">

        <img src="/logo.png"
             class="h-10 w-10 drop-shadow-[0_0_8px_rgba(255,120,0,0.8)]">

        <h1 class="text-2xl font-bold">
            🔥 Flame Force Battle Dashboard
        </h1>

    </div>

    <div class="flex gap-4">

        <a href="/calendar"
           class="bg-orange-600 px-4 py-2 rounded-lg hover:bg-orange-700">
           View Calendar
        </a>

        <a href="/logout"
           class="bg-gray-700 px-4 py-2 rounded-lg hover:bg-gray-600">
           Logout
        </a>

    </div>

</header>


<!-- CREATE BATTLE FORM -->
<% if (roleLevel === "owner" || roleLevel === "admin") { %>

<section class="p-8">

<h2 class="text-xl font-semibold mb-4">
Create New Battle
</h2>

<form action="/create"
      method="POST"
      enctype="multipart/form-data"
      class="grid md:grid-cols-3 gap-4">

<input name="host"
       placeholder="Host Name"
       required
       class="p-3 rounded bg-gray-800">

<input name="opponent"
       placeholder="Opponent Name"
       required
       class="p-3 rounded bg-gray-800">

<input type="date"
       name="date"
       required
       class="p-3 rounded bg-gray-800">

<input type="time"
       name="time"
       required
       class="p-3 rounded bg-gray-800">

<input name="liveLink"
       placeholder="Live Link (optional)"
       class="p-3 rounded bg-gray-800">

<input type="file"
       name="poster"
       accept="image/*"
       class="p-3 rounded bg-gray-800">

<button type="submit"
        class="bg-orange-600 hover:bg-orange-700 rounded px-6 py-3">

Create Battle

</button>

</form>

</section>

<% } %>


<!-- BATTLE GRID -->
<section class="px-8 pb-10">

<h2 class="text-xl font-semibold mb-6">
Scheduled Battles
</h2>

<div class="grid md:grid-cols-3 gap-6">

<% battles.forEach(battle => { %>

<div class="bg-gray-800 rounded-xl shadow-lg p-4">

    <% if (battle.poster) { %>

        <img src="<%= battle.poster %>"
             class="rounded-lg mb-4 w-full object-cover">

    <% } %>

    <h3 class="text-lg font-bold">

        ⚔ <%= battle.host %> vs <%= battle.opponent %>

    </h3>

    <p class="text-gray-400 mb-2">

        📅 <%= battle.date %> ⏰ <%= battle.time %>

    </p>

    <% if (battle.liveLink) { %>

        <a href="<%= battle.liveLink %>"
           target="_blank"
           class="text-orange-400 underline block mb-3">

           Watch Battle

        </a>

    <% } %>


    <% if (roleLevel === "owner" || roleLevel === "admin") { %>

        <form action="/delete/<%= battle.id %>"
              method="POST">

            <button class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded">

                Delete Battle

            </button>

        </form>

    <% } %>

</div>

<% }) %>

</div>

</section>

</body>
</html>