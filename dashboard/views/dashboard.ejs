<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8" />

  <meta
    name="viewport"
    content="width=device-width, initial-scale=1.0"
  />

  <title>Flame Force Dashboard</title>

  <script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-slate-900 text-white min-h-screen">

<div class="max-w-7xl mx-auto p-6">

  <!-- HEADER -->

  <div class="flex flex-col gap-6 mb-8">

    <!-- TITLE -->

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">

      <div>

        <h1 class="text-4xl font-bold text-orange-400">
          🔥 Flame Force Dashboard
        </h1>

        <p class="opacity-70 mt-2">
          Logged in as
          <span class="font-semibold">
            <%= user.username %>
          </span>
        </p>

      </div>

      <div class="flex flex-wrap gap-3">

        <a
          href="/calendar"
          class="bg-indigo-600 hover:bg-indigo-700 px-5 py-3 rounded-xl transition"
        >
          📅 Calendar
        </a>

        <a
          href="/request"
          class="bg-orange-500 hover:bg-orange-600 text-black px-5 py-3 rounded-xl transition font-bold"
        >
          📨 Requests
        </a>

        <a
          href="/logout"
          class="bg-red-600 hover:bg-red-700 px-5 py-3 rounded-xl transition"
        >
          Logout
        </a>

      </div>

    </div>

    <!-- CREATE BATTLE PANEL -->

    <% if (
      roleLevel === "admin" ||
      roleLevel === "owner"
    ) { %>

    <div class="bg-slate-800 border border-orange-500 rounded-2xl p-6 shadow-xl">

      <h2 class="text-2xl font-bold text-orange-400 mb-5">
        ➕ Create Battle
      </h2>

      <form
        action="/battle/create"
        method="POST"
        enctype="multipart/form-data"
        class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4"
      >

        <!-- HOST -->

        <div>

          <label class="block mb-2 text-sm opacity-80">
            Flame Force Host
          </label>

          <select
            name="host"
            required
            class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3"
          >

            <option value="">
              Select Host
            </option>

            <% guildMembers.forEach(member => { %>

              <option value="<%= member.id %>">
                <%= member.name %>
              </option>

            <% }) %>

          </select>

        </div>

        <!-- OPPONENT -->

        <div>

          <label class="block mb-2 text-sm opacity-80">
            Opponent Name
          </label>

          <input
            type="text"
            name="opponent"
            required
            placeholder="Opponent"
            class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3"
          />

        </div>

        <!-- DATE -->

        <div>

          <label class="block mb-2 text-sm opacity-80">
            Date
          </label>

          <input
            type="date"
            name="date"
            required
            class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3"
          />

        </div>

        <!-- TIME -->

        <div>

          <label class="block mb-2 text-sm opacity-80">
            Time
          </label>

          <input
            type="time"
            name="time"
            required
            class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3"
          />

        </div>

        <!-- LIVE LINK -->

        <div>

          <label class="block mb-2 text-sm opacity-80">
            TikTok Live Link
          </label>

          <input
            type="text"
            name="livelink"
            placeholder="https://..."
            class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3"
          />

        </div>

        <!-- POSTER -->

        <div>

          <label class="block mb-2 text-sm opacity-80">
            Battle Poster
          </label>

          <input
            type="file"
            name="poster"
            accept="image/*"
            class="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3"
          />

        </div>

        <!-- TOGGLES -->

        <div class="flex flex-col gap-3 justify-center">

          <label class="flex items-center gap-2">
            <input type="checkbox" name="managergifting">
            🎁 Manager Gifting
          </label>

          <label class="flex items-center gap-2">
            <input type="checkbox" name="adultonly">
            🔞 18+
          </label>

        </div>

        <div class="flex flex-col gap-3 justify-center">

          <label class="flex items-center gap-2">
            <input type="checkbox" name="powerups">
            ⚡ Powerups
          </label>

          <label class="flex items-center gap-2">
            <input type="checkbox" name="nohammers">
            🔨 No Hammers
          </label>

        </div>

        <!-- SUBMIT -->

        <div class="flex items-end">

          <button
            type="submit"
            class="w-full bg-orange-500 hover:bg-orange-600 text-black font-bold px-5 py-3 rounded-xl transition"
          >
            CREATE BATTLE
          </button>

        </div>

      </form>

    </div>

    <% } %>

  </div>

  <!-- BATTLE GRID -->

  <div class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">

  <% if (battles && battles.length) { %>

  <% battles.forEach(b => { %>

  <div class="bg-slate-800 rounded-2xl overflow-hidden shadow-lg border border-slate-700">

    <!-- POSTER -->

    <% if (b.posterdata) { %>

    <img
      src="/poster/<%= b.id %>"
      alt="Battle Poster"
      class="w-full h-[420px] object-cover"
    />

    <% } else { %>

    <div class="w-full h-[420px] bg-slate-700 flex items-center justify-center text-slate-400 text-lg">

      No Poster

    </div>

    <% } %>

    <!-- CONTENT -->

    <div class="p-5">

      <!-- HOST INFO -->

      <div class="flex items-center gap-3 mb-4">

        <% if (b.avatarUrl) { %>

        <img
          src="<%= b.avatarUrl %>"
          class="w-12 h-12 rounded-full border-2 border-orange-500"
        />

        <% } %>

        <div>

          <h2 class="text-xl font-bold">

            <%= b.hostdisplayname || b.host %>

          </h2>

          <p class="text-sm opacity-60">
            vs <%= b.opponent || "Unknown" %>
          </p>

        </div>

      </div>

      <!-- DATE/TIME -->

      <div class="space-y-2 text-sm opacity-80">

        <p>
          📅
          <%= b.date || "—" %>
        </p>

        <p>
          ⏰
          <%= b.time || "—" %>
        </p>

      </div>

      <!-- TAGS -->

      <div class="flex flex-wrap gap-2 mt-5">

        <% if (b.managergifting) { %>

        <span class="bg-purple-600 px-2 py-1 rounded text-xs">
          🎁 Manager Gifting
        </span>

        <% } %>

        <% if (b.adultonly) { %>

        <span class="bg-red-600 px-2 py-1 rounded text-xs">
          🔞 18+
        </span>

        <% } %>

        <% if (b.powerups) { %>

        <span class="bg-yellow-500 text-black px-2 py-1 rounded text-xs">
          ⚡ Powerups
        </span>

        <% } %>

        <% if (b.nohammers) { %>

        <span class="bg-slate-600 px-2 py-1 rounded text-xs">
          🔨 No Hammers
        </span>

        <% } %>

      </div>

      <!-- WATCH LINK -->

      <% if (b.livelink) { %>

      <a
        href="<%= b.livelink %>"
        target="_blank"
        class="mt-5 inline-block bg-indigo-600 hover:bg-indigo-700 px-4 py-2 rounded-lg transition"
      >
        🔗 Watch Battle
      </a>

      <% } %>

      <!-- ADMIN BUTTONS -->

      <% if (
        roleLevel === "admin" ||
        roleLevel === "owner"
      ) { %>

      <div class="flex gap-3 mt-5">

        <a
          href="/battle/<%= b.id %>/edit"
          class="bg-yellow-500 hover:bg-yellow-600 text-black px-4 py-2 rounded-lg transition"
        >
          ✏ Edit
        </a>

        <form
          action="/battle/<%= b.id %>/delete"
          method="POST"
        >

          <button
            class="bg-red-600 hover:bg-red-700 px-4 py-2 rounded-lg transition"
          >
            🗑 Delete
          </button>

        </form>

      </div>

      <% } %>

    </div>

  </div>

  <% }) %>

  <% } else { %>

  <div class="col-span-full text-center opacity-60 py-20 text-xl">

    No battles scheduled yet.

  </div>

  <% } %>

  </div>

</div>

</body>

</html>