<!DOCTYPE html>
<html>
<head>
<title>Flame Force Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-950 text-white min-h-screen">

<div class="max-w-7xl mx-auto p-6">

<!-- HEADER -->
<div class="flex justify-between items-center mb-8">

<h1 class="text-3xl font-bold">
🔥 Flame Force Battle Dashboard
</h1>

<div class="flex gap-4 items-center">

<a href="/" class="bg-orange-600 px-4 py-2 rounded-lg">Dashboard</a>
<a href="/calendar" class="bg-slate-800 px-4 py-2 rounded-lg">Calendar</a>
<a href="/request" class="bg-slate-800 px-4 py-2 rounded-lg">Request Battle</a>

<% if (roleLevel === "owner" || roleLevel === "admin") { %>
<a href="/admin/members" class="bg-indigo-600 px-4 py-2 rounded-lg">Admin Tools</a>
<% } %>

<% if (!user) { %>
<a href="/login" class="bg-indigo-600 px-4 py-2 rounded-lg">Login with Discord</a>
<% } else { %>
<span class="text-slate-400">Logged in as <%= user.username %></span>
<a href="/logout" class="bg-slate-800 px-4 py-2 rounded-lg">Logout</a>
<% } %>

</div>
</div>


<!-- SEARCH + FILTERS -->
<form method="GET" action="/" class="bg-slate-900 p-4 rounded-xl mb-8 border border-slate-800">

<div class="grid md:grid-cols-4 gap-4">

<input
type="text"
name="q"
placeholder="Search host or opponent..."
value="<%= filters.q || '' %>"
class="bg-slate-800 px-4 py-2 rounded-lg w-full"
/>

<select name="host" class="bg-slate-800 px-4 py-2 rounded-lg w-full">
<option value="">Filter by Host</option>
<% agencyMembers.forEach(m => { %>
<option value="<%= m.id %>" <%= filters.host == m.id ? "selected" : "" %>>
<%= m.username %>
</option>
<% }) %>
</select>

<select name="opponent" class="bg-slate-800 px-4 py-2 rounded-lg w-full">
<option value="">Filter by Opponent</option>
<% battles.forEach(b => { %>
<option value="<%= b.opponent %>" <%= filters.opponent == b.opponent ? "selected" : "" %>>
<%= b.opponent %>
</option>
<% }) %>
</select>

<button class="bg-indigo-600 px-4 py-2 rounded-lg w-full">
Search
</button>

</div>

</form>


<!-- CREATE BATTLE (ADMIN/OWNER ONLY) -->
<% if (roleLevel === "owner" || roleLevel === "admin") { %>

<div class="bg-slate-900 p-6 rounded-2xl border border-slate-800 mb-10">

<h2 class="text-xl font-bold mb-4">Create New Battle</h2>

<form action="/create-battle" method="POST" enctype="multipart/form-data" class="space-y-4">

<!-- HOST SELECT -->
<div>
<label class="block mb-1">Host</label>
<select name="host" id="hostSelect" class="bg-slate-800 px-4 py-2 rounded-lg w-full" required>
<option value="">Select Host</option>
<% agencyMembers.forEach(m => { %>
<option value="<%= m.id %>" data-name="<%= m.username %>">
<%= m.username %>
</option>
<% }) %>
</select>
</div>

<!-- HIDDEN HOST NAME -->
<input type="hidden" name="hostName" id="hostNameField" />

<script>
document.getElementById("hostSelect").addEventListener("change", function() {
  const selected = this.options[this.selectedIndex];
  document.getElementById("hostNameField").value = selected.dataset.name || "";
});
</script>

<!-- OPPONENT -->
<div>
<label class="block mb-1">Opponent</label>
<input type="text" name="opponent" class="bg-slate-800 px-4 py-2 rounded-lg w-full" required />
</div>

<!-- DATE + TIME -->
<div class="grid grid-cols-2 gap-4">
<div>
<label class="block mb-1">Date</label>
<input type="date" name="date" class="bg-slate-800 px-4 py-2 rounded-lg w-full" required />
</div>

<div>
<label class="block mb-1">Time</label>
<input type="time" name="time" class="bg-slate-800 px-4 py-2 rounded-lg w-full" required />
</div>
</div>

<!-- FLAGS -->
<div class="grid grid-cols-2 gap-4 text-sm">

<label><input type="checkbox" name="managergifting" /> Manager gifting allowed</label>
<label><input type="checkbox" name="adultonly" /> 18+ only</label>
<label><input type="checkbox" name="powerups" /> Power ups allowed</label>
<label><input type="checkbox" name="nohammers" /> No hammers</label>

</div>

<!-- LIVE LINK -->
<div>
<label class="block mb-1">Live Link (optional)</label>
<input type="url" name="livelink" class="bg-slate-800 px-4 py-2 rounded-lg w-full" />
</div>

<!-- POSTER -->
<div>
<label class="block mb-1">Poster Image (optional)</label>
<input type="file" name="poster" accept="image/*" class="bg-slate-800 px-4 py-2 rounded-lg w-full" />
</div>

<button class="bg-green-600 px-4 py-2 rounded-lg w-full">
Create Battle
</button>

</form>
</div>

<% } %>


<!-- BATTLE LIST -->
<h2 class="text-2xl font-bold mb-4">Upcoming Battles</h2>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% battles.forEach(battle => { %>

<div class="bg-slate-900 rounded-2xl shadow-xl overflow-hidden border border-slate-800">

<!-- POSTER -->
<% if (battle.posterdata) { %>
<img src="/poster/<%= battle.id %>" class="w-full object-cover" />
<% } %>

<div class="p-4">

<!-- TITLE WITH AVATAR -->
<h3 class="text-lg font-bold flex items-center gap-2">

  <% if (battle.avatarUrl) { %>
    <img src="<%= battle.avatarUrl %>" class="w-8 h-8 rounded-full" />
  <% } %>

  <span><%= battle.hostDisplayName %></span>
  <span class="text-slate-400">vs</span>
  <span><%= battle.opponent %></span>

</h3>

<p class="text-sm text-slate-400 mt-1">
📅 <%= battle.date %>  
⏰ <%= battle.time %>
</p>

<!-- FLAGS -->
<div class="mt-2 space-y-1 text-sm">

  <% if (battle.managergifting) { %>
    <p class="text-green-400">Manager gifting allowed</p>
  <% } %>

  <% if (battle.adultonly) { %>
    <p class="text-red-400">18+</p>
  <% } %>

  <% if (battle.powerups) { %>
    <p class="text-yellow-400">Power ups allowed</p>
  <% } %>

  <% if (battle.nohammers) { %>
    <p class="text-purple-400">No hammers</p>
  <% } %>

</div>

<!-- LIVE LINK -->
<% if (battle.livelink) { %>
<a href="<%= battle.livelink %>" target="_blank"
class="inline-block mt-3 bg-red-600 px-4 py-2 rounded-lg">
🔴 Watch Live
</a>
<% } %>

<!-- ADMIN BUTTONS -->
<% if (roleLevel === "owner" || roleLevel === "admin") { %>

<div class="flex gap-2 mt-4">

<!-- EDIT -->
<form action="/battle/<%= battle.id %>/edit" method="POST">
<button class="bg-yellow-600 px-3 py-2 rounded-lg">Edit</button>
</form>

<!-- DELETE -->
<form action="/battle/<%= battle.id %>/delete" method="POST"
onsubmit="return confirm('Delete this battle?');">
<button class="bg-red-600 px-3 py-2 rounded-lg">Delete</button>
</form>

</div>

<% } %>

</div>
</div>

<% }) %>

</div>

</div>
</body>
</html>
