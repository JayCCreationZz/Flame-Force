<!DOCTYPE html>
<html>
<head>
<title>Flame Force Dashboard</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-slate-950 text-white min-h-screen">

<div class="max-w-7xl mx-auto p-6">


<!-- HEADER -->
<div class="flex justify-between items-center mb-8">

<h1 class="text-3xl font-bold">
🔥 Flame Force Dashboard
</h1>

<div class="flex gap-4 items-center">

<a href="/" class="bg-orange-600 px-4 py-2 rounded-lg">
Dashboard
</a>

<a href="/calendar" class="bg-slate-800 px-4 py-2 rounded-lg">
Calendar
</a>

<a href="/request" class="bg-slate-800 px-4 py-2 rounded-lg">
Request Battle
</a>

<% if (!user) { %>

<a href="/login" class="bg-indigo-600 px-4 py-2 rounded-lg">
Login with Discord
</a>

<% } else { %>

<span class="text-slate-400">
Logged in as <%= user.username %>
</span>

<a href="/logout" class="bg-slate-800 px-4 py-2 rounded-lg">
Logout
</a>

<% } %>

</div>
</div>



<!-- CREATE BATTLE PANEL (ADMIN / OWNER ONLY) -->
<% if (roleLevel === "owner" || roleLevel === "admin") { %>

<div class="bg-slate-900 p-6 rounded-2xl shadow-xl mb-10">

<h2 class="text-xl font-semibold mb-4">
Create Battle
</h2>

<form
action="/create-battle"
method="POST"
enctype="multipart/form-data"
class="grid grid-cols-2 gap-4"
>

<!-- HOST DROPDOWN -->
<select
name="host"
required
class="p-2 rounded bg-slate-800"
>
<option value="">Select Host</option>

<% agencyMembers.forEach(m => { %>
<option value="<%= m.id %>" data-name="<%= m.username %>">
<%= m.username %>
</option>
<% }) %>

</select>

<!-- HIDDEN HOSTNAME FIELD -->
<input type="hidden" name="hostName" id="hostNameField">

<script>
document.addEventListener("DOMContentLoaded", () => {
  const hostSelect = document.querySelector("select[name='host']");
  const hostNameField = document.getElementById("hostNameField");

  hostSelect.addEventListener("change", () => {
    const selected = hostSelect.options[hostSelect.selectedIndex];
    hostNameField.value = selected.getAttribute("data-name") || "";
  });
});
</script>

<!-- OPPONENT -->
<input
name="opponent"
required
placeholder="Opponent"
class="p-2 rounded bg-slate-800"
/>

<!-- DATE -->
<input
type="date"
name="date"
required
class="p-2 rounded bg-slate-800"
/>

<!-- TIME -->
<input
type="time"
name="time"
required
class="p-2 rounded bg-slate-800"
/>

<!-- CHECKBOXES -->
<label class="flex gap-2 items-center">
<input type="checkbox" name="managergifting"/>
Manager gifting allowed
</label>

<label class="flex gap-2 items-center">
<input type="checkbox" name="adultonly"/>
18+
</label>

<label class="flex gap-2 items-center">
<input type="checkbox" name="powerups"/>
Power ups allowed
</label>

<label class="flex gap-2 items-center">
<input type="checkbox" name="nohammers"/>
No hammers
</label>

<!-- POSTER -->
<input
type="file"
name="poster"
accept="image/*"
class="col-span-2"
/>

<!-- SUBMIT -->
<button
class="bg-orange-600 hover:bg-orange-500 px-6 py-2 rounded-lg col-span-2"
>
Create Battle
</button>

</form>

</div>

<% } %>



<!-- BATTLE GRID -->
<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% battles.forEach(battle => { %>

<div class="bg-slate-900 rounded-2xl shadow-xl overflow-hidden">

<!-- POSTER -->
<% if (battle.posterdata) { %>
<img
src="/poster/<%= battle.id %>"
class="w-full object-cover"
/>
<% } %>

<div class="p-4">

<h3 class="text-lg font-bold">
<%= battle.hostname || battle.host %> vs <%= battle.opponent %>
</h3>

<p class="text-sm text-slate-400">
📅 <%= battle.date %>  
⏰ <%= battle.time %>
</p>

<!-- FLAGS -->
<% if (battle.managergifting) { %>
<p class="text-green-400 text-sm">Manager gifting allowed</p>
<% } %>

<% if (battle.adultonly) { %>
<p class="text-red-400 text-sm">18+</p>
<% } %>

<% if (battle.powerups) { %>
<p class="text-yellow-400 text-sm">Power ups allowed</p>
<% } %>

<% if (battle.nohammers) { %>
<p class="text-purple-400 text-sm">No hammers</p>
<% } %>

<!-- LIVE LINK -->
<% if (battle.livelink) { %>
<a
href="<%= battle.livelink %>"
target="_blank"
class="inline-block mt-3 bg-red-600 px-4 py-2 rounded-lg"
>
🔴 Watch Live
</a>
<% } %>

</div>
</div>

<% }) %>

</div>

</div>

</body>
</html>
