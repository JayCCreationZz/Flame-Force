<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Flame Force Dashboard</title>

<link rel="icon" href="/favicon.png">

<style>

body{
font-family:Segoe UI;
background:#0d0d0d;
color:#fff;
margin:0;
}

header{
display:flex;
align-items:center;
padding:20px;
background:#111;
border-bottom:2px solid #ff6600;
}

.logo{
height:60px;
margin-right:15px;
}

.container{
padding:30px;
}

form{
background:#111;
padding:20px;
border-radius:10px;
margin-bottom:30px;
}

input,select{
padding:10px;
margin:6px 0;
width:100%;
border-radius:6px;
border:none;
}

button{
background:#ff6600;
border:none;
padding:10px 18px;
color:#fff;
cursor:pointer;
border-radius:6px;
}

button:hover{
background:#ff8533;
}

.battle-card{
background:#111;
padding:15px;
border-radius:10px;
margin-bottom:20px;
border-left:4px solid #ff6600;
}

.poster{
width:200px;
border-radius:10px;
margin-top:10px;
}

.rules{
font-size:13px;
margin-top:8px;
color:#bbb;
}

.actions{
margin-top:10px;
}

</style>
</head>

<body>

<header>
<img src="/logo.png" class="logo">
<h2>Flame Force Battle Dashboard</h2>
</header>

<div class="container">

<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<h3>Create Battle</h3>

<form action="/create" method="POST" enctype="multipart/form-data">

<label>Creator</label>
<select name="host" required>
<% agencyMembers.forEach(member => { %>
<option value="<%= member.id %>">
<%= member.name %>
</option>
<% }) %>
</select>

<label>Opponent</label>
<input type="text" name="opponent" required>

<label>Date</label>
<input type="date" name="date" required>

<label>Time</label>
<input type="time" name="time" required>

<label>Live Link</label>
<input type="text" name="liveLink">

<label>Poster</label>
<input type="file" name="poster" accept="image/*">

<label>Manager Gifting</label>
<select name="managerGifting">
<option value="true">Allowed</option>
<option value="false">Not Allowed</option>
</select>

<label>18+</label>
<select name="adultOnly">
<option value="false">Off</option>
<option value="true">On</option>
</select>

<label>Power Ups</label>
<select name="powerUps">
<option value="true">Allowed</option>
<option value="false">Not Allowed</option>
</select>

<label>No Hammers</label>
<select name="noHammers">
<option value="false">Allowed</option>
<option value="true">No Hammers</option>
</select>

<br><br>
<button>Create Battle</button>

</form>

<% } %>

<h3>Scheduled Battles</h3>

<% battles.forEach(battle => { %>

<div class="battle-card">

<strong>
⚔ <%= battle.hostName %> vs <%= battle.opponent %>
</strong>

<br>
📅 <%= battle.date %>
⏰ <%= battle.time %>

<% if(battle.liveLink){ %>
<br>
🔗 <a href="<%= battle.liveLink %>" target="_blank">
Watch Battle
</a>
<% } %>

<div class="rules">

🎁 Manager Gifting:
<%= battle.managergifting ? "Allowed" : "Not Allowed" %>

|
🔞 18+:
<%= battle.adultonly ? "On" : "Off" %>

|
⚡ Power Ups:
<%= battle.powerups ? "Allowed" : "Not Allowed" %>

|
🔨 No Hammers:
<%= battle.nohammers ? "Yes" : "No" %>

</div>

<img class="poster"
src="/poster/<%= battle.id %>">

<% if(roleLevel === "owner" || roleLevel === "admin"){ %>

<div class="actions">

<form action="/delete/<%= battle.id %>" method="POST">
<button>Delete</button>
</form>

</div>

<% } %>

</div>

<% }) %>

</div>

</body>
</html>