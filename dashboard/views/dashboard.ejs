<!DOCTYPE html>
<html>
<head>
<meta charset="UTF-8">
<title>Flame Force Control Panel</title>

<link rel="icon" href="/favicon.png">

<style>

body{
margin:0;
font-family:Segoe UI,Arial;
background:linear-gradient(180deg,#0b0b0b,#151515);
color:white;
}

/* HEADER */

header{
display:flex;
justify-content:space-between;
align-items:center;
padding:18px 40px;
background:#0f0f0f;
border-bottom:2px solid #ff6600;
position:sticky;
top:0;
z-index:999;
}

/* LOGO */

.logo{
display:flex;
align-items:center;
gap:12px;
}

.logo img{
height:48px;
animation:glowPulse 2.5s infinite alternate ease-in-out;
}

@keyframes glowPulse{
0%{filter:drop-shadow(0 0 6px #ff6600);}
100%{filter:drop-shadow(0 0 22px #ffaa00);}
}

/* NAV */

.nav a{
margin-left:24px;
color:#ff6600;
font-weight:600;
text-decoration:none;
}

/* PAGE WRAPPER */

.wrapper{
padding:40px;
max-width:1300px;
margin:auto;
}

/* PANEL */

.panel{
background:#181818;
padding:26px;
border-radius:14px;
box-shadow:0 0 25px rgba(255,110,0,.15);
margin-bottom:40px;
}

/* FORM GRID */

.form-grid{
display:grid;
grid-template-columns:1fr 1fr;
gap:18px;
}

/* INPUTS */

input,select{
width:100%;
padding:12px;
border:none;
border-radius:8px;
background:#101010;
color:white;
}

/* BUTTON */

button{
border:none;
padding:12px 20px;
border-radius:8px;
cursor:pointer;
font-weight:600;
}

.create-btn{
background:linear-gradient(90deg,#ff6600,#ff3300);
color:white;
}

/* BATTLE GRID */

.battle-grid{
display:grid;
grid-template-columns:repeat(auto-fill,minmax(320px,1fr));
gap:28px;
}

/* CARD */

.card{
background:#1b1b1b;
border-radius:16px;
padding:22px;
box-shadow:0 0 18px rgba(255,100,0,.12);
transition:.25s;
}

.card:hover{
transform:translateY(-6px);
box-shadow:0 0 30px rgba(255,120,0,.25);
}

/* POSTER */

.poster{
width:100%;
border-radius:12px;
margin-top:12px;
}

/* TOOLBAR */

.toolbar{
margin-top:14px;
display:flex;
gap:10px;
}

.edit-btn{
background:#ffaa00;
}

.delete-btn{
background:#ff3333;
color:white;
}

/* LABEL */

label{
font-size:13px;
opacity:.7;
}

.section-title{
margin-bottom:18px;
color:#ffaa00;
}

</style>
</head>

<body>

<header>

<div class="logo">
<img src="/logo.png">
<h2>Flame Force Control Panel</h2>
</div>

<div class="nav">
<a href="/dashboard">Dashboard</a>
<a href="/calendar">Calendar</a>
<a href="/logout">Logout</a>
</div>

</header>

<div class="wrapper">

<% if(roleLevel==="owner" || roleLevel==="admin"){ %>

<div class="panel">

<h2 class="section-title">Create Battle</h2>

<form action="/create" method="POST" enctype="multipart/form-data">

<div class="form-grid">

<div>
<label>Host Creator</label>
<select name="host">
<% agencyMembers.forEach(member=>{ %>
<option value="<%=member.id%>">
<%=member.name%>
</option>
<% }) %>
</select>
</div>

<div>
<label>Opponent</label>
<input name="opponent"
placeholder="TikTok username">
</div>

<div>
<label>Date</label>
<input type="date" name="date">
</div>

<div>
<label>Time</label>
<input type="time" name="time">
</div>

<div>
<label>Live Link</label>
<input name="liveLink">
</div>

<div>
<label>Poster Upload</label>
<input type="file" name="poster">
</div>

</div>

<br>

<button class="create-btn">
Create Battle
</button>

</form>

</div>

<% } %>


<h2 class="section-title">Scheduled Battles</h2>

<div class="battle-grid">

<% battles.forEach(battle=>{ %>

<div class="card">

<form
action="/edit/<%=battle.id%>"
method="POST"
enctype="multipart/form-data">

<label>Host</label>

<select name="host">
<% agencyMembers.forEach(member=>{ %>
<option value="<%=member.id%>"
<%=member.id==battle.host?"selected":""%>>
<%=member.name%>
</option>
<% }) %>
</select>

<label>Opponent</label>

<input
name="opponent"
value="<%=battle.opponent%>">

<label>Date</label>

<input
type="date"
name="date"
value="<%=battle.date%>">

<label>Time</label>

<input
type="time"
name="time"
value="<%=battle.time%>">

<label>Live Link</label>

<input
name="liveLink"
value="<%=battle.liveLink||""%>">

<label>Replace Poster</label>

<input type="file" name="poster">

<% if(battle.poster){ %>

<img
class="poster"
src="<%=battle.poster%>">

<% } %>

<% if(roleLevel==="owner"||roleLevel==="admin"){ %>

<div class="toolbar">

<button class="edit-btn">
Save
</button>

</form>

<form
action="/delete/<%=battle.id%>"
method="POST">

<button class="delete-btn">
Delete
</button>

</form>

</div>

<% } %>

</div>

<% }) %>

</div>

</div>

</body>
</html>