<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">

<title>Battle Request</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-slate-950 text-white min-h-screen flex flex-col items-center">

<!-- HEADER -->

<div class="w-full bg-slate-900 shadow-lg px-6 py-4 flex justify-between items-center">

<div class="flex items-center gap-4">

<img src="/logo.png" class="h-10 animate-pulse">

<h1 class="text-xl font-bold text-orange-400">
Battle Request Form
</h1>

</div>

<a href="/calendar"
class="bg-orange-500 px-4 py-2 rounded-lg hover:bg-orange-600">
View Calendar
</a>

</div>


<!-- FORM CARD -->

<div class="mt-10 w-full max-w-xl bg-slate-900 rounded-2xl shadow-xl p-6">

<h2 class="text-lg font-semibold text-orange-400 mb-4">
Request a Battle With Our Creators
</h2>


<form action="/request" method="POST" class="space-y-4">


<label>Agency Name</label>

<input
name="agency"
required
class="w-full px-3 py-2 rounded-lg bg-slate-800"
/>


<label>Your Creator Name</label>

<input
name="requester"
required
class="w-full px-3 py-2 rounded-lg bg-slate-800"
/>


<label>Opponent Creator</label>

<input
name="opponent"
required
class="w-full px-3 py-2 rounded-lg bg-slate-800"
/>


<div class="grid grid-cols-2 gap-3">

<div>

<label>Preferred Date</label>

<input
type="date"
name="preferred_date"
required
class="w-full px-3 py-2 rounded-lg bg-slate-800"
/>

</div>


<div>

<label>Preferred Time</label>

<input
type="time"
name="preferred_time"
required
class="w-full px-3 py-2 rounded-lg bg-slate-800"
/>

</div>

</div>


<label>Additional Notes</label>

<textarea
name="notes"
rows="3"
class="w-full px-3 py-2 rounded-lg bg-slate-800"
></textarea>


<button
type="submit"
class="w-full bg-orange-500 hover:bg-orange-600 py-2 rounded-lg font-semibold"
>

Submit Battle Request 🚀

</button>

</form>

</div>


<!-- SUCCESS MESSAGE -->

<% if(success){ %>

<div class="mt-6 bg-green-600 px-6 py-3 rounded-lg">

Request submitted successfully!

</div>

<% } %>


</body>
</html>