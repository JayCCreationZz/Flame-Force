### Status Badges

Replace your entire `statusBadge()` function with:

```ejs
<%
function statusBadge(status) {

  if (status === "live")
    return '<span class="bg-red-700 text-white px-2 py-1 rounded text-xs">⚔️ LIVE</span>';

  if (status === "soon")
    return '<span class="bg-purple-700 text-white px-2 py-1 rounded text-xs">⚔️ SOON</span>';

  if (status === "upcoming")
    return '<span class="bg-green-700 text-white px-2 py-1 rounded text-xs">⚔️ UPCOMING</span>';

  if (status === "past")
    return '<span class="bg-slate-700 text-white px-2 py-1 rounded text-xs">⚔️ PAST</span>';

  return "";
}
%>
```

