<!DOCTYPE html>
<html>
<head>

<title>Battle Calendar</title>

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-slate-950 text-white min-h-screen">

<div class="max-w-6xl mx-auto p-6">

<h1 class="text-3xl font-bold mb-6">
📅 Flame Force Battle Calendar
</h1>


<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% battles.forEach(battle => { %>

<div class="bg-slate-900 rounded-2xl shadow-xl overflow-hidden">

<% if (battle.posterdata) { %>

<img
src="/poster/<%= battle.id %>"
class="w-full object-cover"
/>

<% } %>

<div class="p-4">

<h3 class="text-lg font-bold">

<%= battle.hostname || battle.host %>
vs
<%= battle.opponent %>

</h3>

<p class="text-sm text-slate-400">

📅 <%= battle.date %>
⏰ <%= battle.time %>

</p>


<% if (battle.livelink) { %>

<a
href="<%= battle.livelink %>"
target="_blank"
class="inline-block mt-3 bg-red-600 px-4 py-2 rounded-lg"
>
🔴 Watch Live
</a>

<% } %>

</div>

</div>

<% }) %>

</div>

</div>

</body>
</html>