<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Flame Force Battle Calendar</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>

/* BACKGROUND */

body{
background:linear-gradient(135deg,#020617,#0f172a);
}

/* GLASS CARD */

.card{
background:rgba(30,41,59,.75);
backdrop-filter:blur(14px);
border-radius:18px;
border:1px solid rgba(255,80,0,.25);
transition:.25s ease;
}

.card:hover{
transform:translateY(-4px);
box-shadow:
0 0 25px rgba(255,80,0,.45),
0 0 45px rgba(255,20,0,.25);
}

/* POSTER */

.poster{
border-radius:12px;
max-height:180px;
object-fit:cover;
}

/* LOGO GLOW */

.logo{
animation:pulseGlow 2.5s infinite ease-in-out;
}

@keyframes pulseGlow{

0%{
filter:drop-shadow(0 0 8px rgba(255,80,0,.4));
}

50%{
filter:
drop-shadow(0 0 22px rgba(255,80,0,.9))
drop-shadow(0 0 40px rgba(255,40,0,.5));
}

100%{
filter:drop-shadow(0 0 8px rgba(255,80,0,.4));
}

}

</style>

</head>

<body class="text-white min-h-screen">

<div class="max-w-7xl mx-auto px-6 py-10">

<!-- HEADER -->

<div class="flex items-center justify-between mb-10">

<div class="flex items-center gap-4">

<img
src="/logo.png"
class="logo w-14 h-14"
/>

<h1 class="text-3xl font-bold">
Flame Force Battle Calendar
</h1>

</div>

<div class="flex gap-3">

<a
href="/dashboard"
class="bg-orange-500 hover:bg-orange-600 px-5 py-2 rounded-xl shadow">

Dashboard 🔥

</a>

<a
href="/logout"
class="bg-red-600 hover:bg-red-700 px-5 py-2 rounded-xl shadow">

Logout

</a>

</div>

</div>


<!-- BATTLE GRID -->

<% if(!battles.length){ %>

<div class="text-gray-400 text-lg">
No battles scheduled yet ⚔
</div>

<% } else { %>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% battles.forEach(battle => { %>

<div class="card p-5">

<!-- POSTER -->

<img
src="/poster/<%= battle.id %>?t=<%= Date.now() %>"
class="poster mb-4"
/>


<!-- TITLE -->

<h3 class="text-lg font-semibold text-orange-400">

🔥 <%= battle.hostName || battle.host %>
vs
<%= battle.opponent %>

</h3>


<!-- DATE -->

<p class="text-gray-300">
📅 <%= battle.date %>
</p>


<!-- TIME -->

<p class="text-gray-300 mb-3">
⏰ <%= battle.time %>
</p>


<!-- LIVE LINK -->

<% if(battle.liveLink){ %>

<a
href="<%= battle.liveLink %>"
target="_blank"
class="inline-block bg-orange-500 hover:bg-orange-600 px-3 py-2 rounded-lg">

Watch Battle 🔗

</a>

<% } %>

</div>

<% }) %>

</div>

<% } %>

</div>

</body>
</html>