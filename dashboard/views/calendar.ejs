<!DOCTYPE html>
<html lang="en">
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Flame Force Battle Calendar</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>

body{
background:linear-gradient(135deg,#020617,#0f172a);
}

.card{
background:rgba(30,41,59,.75);
backdrop-filter:blur(14px);
border-radius:18px;
border:1px solid rgba(255,80,0,.25);
transition:.25s ease;
}

.card:hover{
transform:translateY(-4px);
box-shadow:
0 0 25px rgba(255,80,0,.45),
0 0 45px rgba(255,20,0,.25);
}

.poster{
border-radius:12px;
max-height:180px;
object-fit:cover;
}

.logo{
animation:pulseGlow 2.5s infinite ease-in-out;
}

@keyframes pulseGlow{

0%{
filter:drop-shadow(0 0 8px rgba(255,80,0,.4));
}

50%{
filter:
drop-shadow(0 0 22px rgba(255,80,0,.9))
drop-shadow(0 0 40px rgba(255,40,0,.5));
}

100%{
filter:drop-shadow(0 0 8px rgba(255,80,0,.4));
}

}

.sectionTitle{
font-size:1.6rem;
font-weight:600;
margin-bottom:1rem;
color:#fb923c;
}

</style>

</head>

<body class="text-white min-h-screen">

<div class="max-w-7xl mx-auto px-6 py-10">

<!-- HEADER -->

<div class="flex items-center justify-between mb-10">

<div class="flex items-center gap-4">

<img src="/logo.png" class="logo w-14 h-14"/>

<h1 class="text-3xl font-bold">
Flame Force Battle Calendar
</h1>

</div>

<div class="flex gap-3">

<a href="/dashboard"
class="bg-orange-500 hover:bg-orange-600 px-5 py-2 rounded-xl shadow">
Dashboard 🔥
</a>

<a href="/logout"
class="bg-red-600 hover:bg-red-700 px-5 py-2 rounded-xl shadow">
Logout
</a>

</div>

</div>


<%
function parseDate(d){
  const [day,month,year]=d.split("/");
  return new Date(`${year}-${month}-${day}`);
}

const today=new Date();
today.setHours(0,0,0,0);

const tomorrow=new Date(today);
tomorrow.setDate(today.getDate()+1);

const todayBattles=[];
const tomorrowBattles=[];
const upcomingBattles=[];

battles.forEach(b=>{

const battleDate=parseDate(b.date);

if(battleDate.getTime()===today.getTime())
todayBattles.push(b);

else if(battleDate.getTime()===tomorrow.getTime())
tomorrowBattles.push(b);

else if(battleDate>tomorrow)
upcomingBattles.push(b);

});
%>


<!-- TODAY -->

<% if(todayBattles.length){ %>

<div class="mb-12">

<div class="sectionTitle">
🔥 Today’s Battles
</div>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% todayBattles.forEach(battle=>{ %>

<div class="card p-5">

<img
src="/poster/<%= battle.id %>?t=<%= Date.now() %>"
class="poster mb-4"
/>

<h3 class="text-lg font-semibold text-orange-400">

🔥 <%= battle.hostName || battle.host %>
vs
<%= battle.opponent %>

</h3>

<p class="text-gray-300">
⏰ <%= battle.time %>
</p>

<% if(battle.liveLink){ %>

<a
href="<%= battle.liveLink %>"
target="_blank"
class="inline-block mt-3 bg-orange-500 hover:bg-orange-600 px-3 py-2 rounded-lg">

Watch Battle 🔗

</a>

<% } %>

</div>

<% }) %>

</div>

</div>

<% } %>


<!-- TOMORROW -->

<% if(tomorrowBattles.length){ %>

<div class="mb-12">

<div class="sectionTitle">
⚡ Tomorrow’s Battles
</div>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% tomorrowBattles.forEach(battle=>{ %>

<div class="card p-5">

<img
src="/poster/<%= battle.id %>?t=<%= Date.now() %>"
class="poster mb-4"
/>

<h3 class="text-lg font-semibold text-orange-400">

🔥 <%= battle.hostName || battle.host %>
vs
<%= battle.opponent %>

</h3>

<p class="text-gray-300">
⏰ <%= battle.time %>
</p>

</div>

<% }) %>

</div>

</div>

<% } %>


<!-- UPCOMING -->

<% if(upcomingBattles.length){ %>

<div class="mb-12">

<div class="sectionTitle">
📅 Upcoming Battles
</div>

<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% upcomingBattles.forEach(battle=>{ %>

<div class="card p-5">

<img
src="/poster/<%= battle.id %>?t=<%= Date.now() %>"
class="poster mb-4"
/>

<h3 class="text-lg font-semibold text-orange-400">

🔥 <%= battle.hostName || battle.host %>
vs
<%= battle.opponent %>

</h3>

<p class="text-gray-300">
📅 <%= battle.date %>
⏰ <%= battle.time %>
</p>

</div>

<% }) %>

</div>

</div>

<% } %>


<% if(
!todayBattles.length &&
!tomorrowBattles.length &&
!upcomingBattles.length
){ %>

<div class="text-gray-400 text-lg">
No battles scheduled ⚔
</div>

<% } %>

</div>

</body>
</html>