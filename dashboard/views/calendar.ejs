<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Flame Force Calendar</title>

<link rel="icon" type="image/png" href="/favicon.png">

<script src="https://cdn.tailwindcss.com"></script>

</head>

<body class="bg-gray-900 text-white min-h-screen">

<header class="flex justify-between items-center px-8 py-4 bg-gray-800 shadow-lg">

<div class="flex items-center gap-4">

<img src="/logo.png"
class="h-12 w-12">

<h1 class="text-2xl font-bold">
🔥 Flame Force Battle Calendar
</h1>

</div>

<a href="/dashboard"
class="bg-orange-600 px-4 py-2 rounded hover:bg-orange-700">

Back to Dashboard

</a>

</header>


<section class="p-8">

<div class="grid md:grid-cols-3 gap-6">

<% battles.forEach(battle => { %>

<div class="bg-gray-800 rounded-xl shadow-lg p-4">

<% if (battle.poster) { %>

<img src="<%= battle.poster %>"
class="rounded-lg mb-4 w-full object-cover">

<% } %>

<h3 class="text-lg font-bold">

⚔
<%= agencyMembers.find(m => m.id === battle.host)?.name || battle.host %>
vs
<%= agencyMembers.find(m => m.id === battle.opponent)?.name || battle.opponent %>

</h3>

<p class="text-gray-400 mb-2">

📅 <%= battle.date %> ⏰ <%= battle.time %>

</p>

<% if (battle.liveLink) { %>

<a href="<%= battle.liveLink %>"
target="_blank"
class="text-orange-400 underline">

Watch Battle

</a>

<% } %>

</div>

<% }) %>

</div>

</section>

</body>
</html>