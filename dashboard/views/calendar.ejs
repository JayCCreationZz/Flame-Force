<!DOCTYPE html>
<html>
<head>

<title>Flame Force Calendar</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>

body{
background:linear-gradient(135deg,#020617,#0f172a);
color:white;
}

.card{
background:rgba(30,41,59,.75);
backdrop-filter:blur(12px);
border-radius:18px;
border:1px solid rgba(255,80,0,.25);
transition:.2s;
}

.card:hover{
transform:translateY(-4px);
box-shadow:
0 0 20px rgba(255,80,0,.4),
0 0 35px rgba(255,30,0,.25);
}

.poster{
border-radius:12px;
max-height:180px;
object-fit:cover;
}

.logo{
animation:pulseGlow 2.4s infinite ease-in-out;
}

@keyframes pulseGlow{

0%{
filter:drop-shadow(0 0 8px rgba(255,80,0,.5));
}

50%{
filter:
drop-shadow(0 0 25px rgba(255,80,0,.95))
drop-shadow(0 0 45px rgba(255,40,0,.45));
}

100%{
filter:drop-shadow(0 0 8px rgba(255,80,0,.5));
}

}

.liveBadge{
background:#ef4444;
padding:4px 10px;
border-radius:999px;
font-size:.8rem;
margin-left:10px;
}

.soonBadge{
background:#f97316;
padding:4px 10px;
border-radius:999px;
font-size:.8rem;
margin-left:10px;
}

</style>

</head>

<body>

<div class="max-w-7xl mx-auto px-6 py-10">

<div class="flex justify-between items-center mb-10">

<div class="flex gap-4 items-center">

<img src="/logo.png" class="logo w-14"/>

<h1 class="text-3xl font-bold">
Flame Force Calendar
</h1>

</div>

<a href="/dashboard"
class="bg-orange-500 px-5 py-2 rounded-xl">
Back to Dashboard
</a>

</div>


<%

function parseDateTime(date,time){

const [d,m,y]=date.split("/");
const [h,min]=time.split(":");

return new Date(y,m-1,d,h,min);

}

const now=new Date();

function getStatus(date,time){

const battleDate=parseDateTime(date,time);

const diff=(battleDate-now)/60000;

if(diff<=0 && diff>-120)
return "live";

if(diff>0 && diff<=30)
return "soon";

return "none";

}

%>


<div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">

<% battles.forEach(b=>{

const status=getStatus(b.date,b.time);

%>

<div class="card p-5">

<img
src="/poster/<%= b.id %>?t=<%= Date.now() %>"
class="poster mb-4"
/>

<h3 class="text-lg font-semibold text-orange-400">

🔥 <%= b.hostName || b.host %>
vs
<%= b.opponent %>

<% if(status==="live"){ %>

<span class="liveBadge">
LIVE NOW
</span>

<% } %>

<% if(status==="soon"){ %>

<span class="soonBadge">
STARTING SOON
</span>

<% } %>

</h3>

<p class="text-gray-300">
📅 <%= b.date %>
⏰ <%= b.time %>
</p>

<% if(b.liveLink){ %>

<a
href="<%= b.liveLink %>"
target="_blank"
class="inline-block mt-3 bg-orange-500 px-3 py-2 rounded-lg">

Watch Battle 🔗

</a>

<% } %>

</div>

<% }) %>

</div>

</div>

</body>
</html>